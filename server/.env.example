PORT=3001
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ─────────────────────────────────────────────────────────────────────────────
# Database — Supabase PostgreSQL (Session Pooler – IPv4 compatible)
# ⚠️  Dùng Session Pooler, KHÔNG dùng Direct Connection (sẽ bị timeout IPv6)
# Lấy tại: Supabase Dashboard → Connect → Connection Pooling → Session mode
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.intjyzfknmtzldpvctxa
DB_PASSWORD=your_db_password_here
DB_SSL=true

# JWT — tự đặt chuỗi bí mật bất kỳ (>= 32 ký tự)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Email (Gmail SMTP) — bật "App Password" tại myaccount.google.com/apppasswords
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_gmail_app_password

# Cloudinary — lấy tại cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gemini AI — lấy tại aistudio.google.com/app/apikey
GEMINI_API_KEY=
